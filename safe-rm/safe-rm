#!/bin/bash
# Check if the user passed -r, -R, or --recursive
files=()
is_recursive=false
for arg in "$@"; do
    case "$arg" in
        --recursive) is_recursive=true ;;
        -*[Rr]*) is_recursive=true ;;
	-*) ;;
	*) files+=("$arg") ;;
    esac
done


# Bypass if not interactive, no files, or NOT recursive
if [[ ! -t 0 || ${#files[@]} -eq 0 || "$is_recursive" = false ]]; then
    /bin/rm "$@"
    exit $?
fi

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/safe-rm"
mkdir -p "$STATE_DIR"

log_name="$(whoami)_$(id -u)-$(date '+%m_%d_%Y-%H%M_%S').log"
log_file="$STATE_DIR/$log_name"

phrases=("eradicate them" "remove them" "send them away" "delete them" "confirm" "proceed")

# Calculate index based on arguments and cwd
total_string=$(pwd)"$*"
index=$(( ${#total_string} % ${#phrases[@]} ))
required_phrase="${phrases[$index]}"

count=$(find "${files[@]}" -maxdepth 100 2>/dev/null | wc -l)
if [ "$count" -eq 1 ]; then
	/bin/rm "$@"
	exit $?
fi

echo "WARNING: You are about to delete $count files at the following path(s):"

# Resolve and print absolute paths for each arg
for arg in "${files[@]}"; do
	abs_path=$(realpath -sm -- "$arg")

	# Only attempt to resolve if the file/dir exists
	if [ -e "$arg" ]; then
		echo "  $arg -> $abs_path"
	else
		echo "  $arg -> not found"
	fi
done

echo -e "\nType '$required_phrase' to proceed."
printf " > "
read -r user_input

if [ "$user_input" = "$required_phrase" ]; then
	/bin/rm "$@"
else
	{
	    echo "TIMESTAMP: $(date)"
	    echo "USER:      $(whoami) (UID: $(id -u))"
	    echo "CWD:       $(pwd)"
	    echo "COMMAND:   rm $*"
	    echo "PHRASE:    Expected '$required_phrase', got '$user_input'"
	    echo "--- ARGS RESOLVED ---"
	    for arg in "$@"; do
	        echo "  $arg -> $(realpath -sm -- "$arg")"
	    done
	} > "$log_file"
	
	echo "Action cancelled. Your files are safe."
	echo "Incident report created: $log_file"
	exit 1
fi

